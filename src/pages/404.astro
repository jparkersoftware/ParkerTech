---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page not found">
  <main class="notfound">
    <div class="notfound-glow" aria-hidden="true"></div>
    <p class="notfound-code grad-text">404</p>
    <h1>This page wandered off.</h1>
    <p class="notfound-text">
      The page you're looking for doesn't exist or has moved.
    </p>
    <a class="btn btn-primary" href="/">Back to home</a>
  </main>
</Layout>

<style>
  .notfound {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 0.6rem;
    padding: 2rem;
    overflow: hidden;
  }
  .notfound-glow {
    position: absolute;
    width: 460px;
    height: 460px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(13, 148, 136, 0.3), transparent 68%);
    filter: blur(120px);
    z-index: 0;
  }
  .notfound > *:not(.notfound-glow) {
    position: relative;
    z-index: 1;
  }
  .notfound-code {
    font-family: var(--font-display);
    font-size: clamp(5rem, 18vw, 9rem);
    font-weight: 700;
    line-height: 1;
  }
  .notfound h1 {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
  }
  .notfound-text {
    color: var(--text-muted);
    margin-bottom: 1.4rem;
  }
</style>
