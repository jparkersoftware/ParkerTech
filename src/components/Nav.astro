---
import { site } from '../data/site';
import Icon from './Icon.astro';

const links = [
  { href: '#projects', label: 'Projects' },
  { href: '#about', label: 'About' },
  { href: '#contact', label: 'Contact' },
];
---

<header class="nav" id="site-nav" data-state="top">
  <div class="container nav-inner">
    <a class="brand" href="#top" aria-label={`${site.brand} — home`}>
      <span class="brand-mark" aria-hidden="true">P</span>
      <span class="brand-word">Parker<span class="brand-accent">Tech</span></span>
    </a>

    <nav class="nav-links" aria-label="Primary">
      {links.map((l) => <a href={l.href} data-navlink={l.href}>{l.label}</a>)}
    </nav>

    <div class="nav-actions">
      <a class="btn btn-primary nav-cta" href="#contact">Get in touch</a>
      <button
        class="nav-toggle"
        id="nav-toggle"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="nav-toggle-icon nav-toggle-open"><Icon name="menu" size={22} /></span>
        <span class="nav-toggle-icon nav-toggle-close"><Icon name="close" size={22} /></span>
      </button>
    </div>
  </div>

  <div class="mobile-menu" id="mobile-menu" hidden>
    <nav aria-label="Mobile">
      {links.map((l) => <a href={l.href} data-mobilelink>{l.label}</a>)}
    </nav>
    <a class="btn btn-primary" href="#contact" data-mobilelink>Get in touch</a>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--nav-h);
    display: flex;
    align-items: center;
    transition: background-color 0.3s var(--ease), border-color 0.3s var(--ease),
      backdrop-filter 0.3s var(--ease), box-shadow 0.3s var(--ease);
    border-bottom: 1px solid transparent;
  }
  .nav[data-state='scrolled'] {
    background: rgba(250, 248, 243, 0.85);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom-color: var(--border);
    box-shadow: 0 8px 30px -20px rgba(36, 31, 24, 0.4);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    width: 100%;
  }

  /* brand */
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.12rem;
    letter-spacing: -0.01em;
  }
  .brand-mark {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 9px;
    background: var(--grad-soft);
    color: #fff;
    font-weight: 700;
    font-size: 1.05rem;
    box-shadow: 0 6px 16px -6px rgba(13, 148, 136, 0.6);
  }
  .brand-accent {
    color: var(--accent-deep);
  }

  /* desktop links */
  .nav-links {
    display: flex;
    gap: 0.35rem;
    margin-inline-start: auto;
  }
  .nav-links a {
    position: relative;
    padding: 0.5rem 0.85rem;
    border-radius: var(--radius-pill);
    color: var(--text-muted);
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s var(--ease), background-color 0.2s var(--ease);
  }
  .nav-links a:hover {
    color: var(--text);
    background: var(--fill);
  }
  .nav-links a[data-active='true'] {
    color: var(--accent-deep);
  }
  .nav-links a[data-active='true']::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: 0.1rem;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    transform: translateX(-50%);
    background: var(--accent);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .nav-cta {
    --btn-pad-y: 0.6rem;
    --btn-pad-x: 1.15rem;
    font-size: 0.9rem;
  }

  /* mobile toggle */
  .nav-toggle {
    display: none;
    position: relative;
    width: 42px;
    height: 42px;
    border-radius: 10px;
    background: var(--surface);
    border: 1px solid var(--border-strong);
    cursor: pointer;
    color: var(--text);
  }
  .nav-toggle-icon {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    transition: opacity 0.18s var(--ease), transform 0.18s var(--ease);
  }
  .nav-toggle-close {
    opacity: 0;
    transform: rotate(-45deg);
  }
  .nav[data-menu='open'] .nav-toggle-open {
    opacity: 0;
    transform: rotate(45deg);
  }
  .nav[data-menu='open'] .nav-toggle-close {
    opacity: 1;
    transform: rotate(0);
  }

  /* mobile menu panel */
  .mobile-menu {
    position: absolute;
    top: var(--nav-h);
    left: 0;
    right: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1rem clamp(1.25rem, 5vw, 2.5rem) 1.5rem;
    background: rgba(250, 248, 243, 0.98);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border);
    box-shadow: var(--shadow);
  }
  .mobile-menu[hidden] {
    display: none;
  }
  .mobile-menu nav {
    display: flex;
    flex-direction: column;
  }
  .mobile-menu nav a {
    padding: 0.85rem 0.5rem;
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
  }
  .mobile-menu nav a:hover {
    color: var(--text);
  }
  .mobile-menu .btn {
    margin-top: 0.9rem;
  }

  @media (max-width: 720px) {
    .nav-links,
    .nav-cta {
      display: none;
    }
    .nav-toggle {
      display: block;
    }
  }
</style>

<script>
  const nav = document.getElementById('site-nav') as HTMLElement;
  const toggle = document.getElementById('nav-toggle') as HTMLButtonElement;
  const menu = document.getElementById('mobile-menu') as HTMLElement;

  // Solidify the nav background once the page is scrolled.
  const onScroll = () => {
    nav.dataset.state = window.scrollY > 24 ? 'scrolled' : 'top';
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // Mobile menu open / close.
  const setMenu = (open: boolean) => {
    nav.dataset.menu = open ? 'open' : 'closed';
    menu.hidden = !open;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  };
  toggle.addEventListener('click', () => setMenu(menu.hidden));
  menu.querySelectorAll('[data-mobilelink]').forEach((link) => {
    link.addEventListener('click', () => setMenu(false));
  });

  // Highlight the nav link for the section currently in view.
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('[data-navlink]');
  const sections = ['projects', 'about', 'contact']
    .map((id) => document.getElementById(id))
    .filter((el): el is HTMLElement => el !== null);

  if ('IntersectionObserver' in window && sections.length) {
    const spy = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            navLinks.forEach((link) => {
              link.dataset.active = String(link.dataset.navlink === `#${entry.target.id}`);
            });
          }
        });
      },
      { rootMargin: '-45% 0px -50% 0px' }
    );
    sections.forEach((section) => spy.observe(section));
  }
</script>
