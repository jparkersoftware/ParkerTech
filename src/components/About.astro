---
import { site } from '../data/site';

const { about } = site;
---

<section class="section about" id="about">
  <div class="container">
    <div class="section-head" data-reveal>
      <span class="eyebrow">01 — About</span>
      <h2 class="section-title">From the classroom to the codebase.</h2>
    </div>

    <div class="about-grid">
      <div class="about-bio" data-reveal>
        {about.paragraphs.map((para) => <p>{para}</p>)}

        <div class="about-stats">
          {
            about.stats.map((stat) => (
              <div class="stat">
                <span class="stat-value grad-text">{stat.value}</span>
                <span class="stat-label">{stat.label}</span>
              </div>
            ))
          }
        </div>
      </div>

      <aside class="about-card" data-reveal style="--reveal-delay: 120ms">
        <p class="about-card-title">
          <span class="about-card-dot" aria-hidden="true"></span>
          What I can help with
        </p>
        <div class="cap-groups">
          {
            about.capabilities.map((group) => (
              <div class="cap-group">
                <h3 class="cap-group-name">{group.group}</h3>
                <ul class="cap-tags">
                  {group.items.map((item) => (
                    <li class="cap-tag">{item}</li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(1.5rem, 4vw, 3.25rem);
    align-items: start;
  }

  /* bio */
  .about-bio p {
    color: var(--text-muted);
    font-size: 1.06rem;
  }
  .about-bio p + p {
    margin-top: 1.1rem;
  }

  .about-stats {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    border-top: 1px solid var(--border);
    padding-top: 2rem;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .stat-value {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    font-weight: 700;
    line-height: 1;
  }
  .stat-label {
    font-size: 0.86rem;
    color: var(--text-dim);
  }

  /* "what I can help with" card */
  .about-card {
    position: relative;
    padding: 1.75rem;
    border-radius: var(--radius);
    background: var(--surface);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    overflow: hidden;
  }
  .about-card::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: var(--grad);
  }
  .about-card-title {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }
  .about-card-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-tint);
  }

  .cap-groups {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }
  .cap-group-name {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 0.7rem;
  }
  .cap-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .cap-tag {
    padding: 0.4rem 0.8rem;
    border-radius: var(--radius-pill);
    background: var(--fill);
    border: 1px solid var(--border);
    font-size: 0.86rem;
    color: var(--text);
    transition: border-color 0.2s var(--ease), color 0.2s var(--ease),
      background-color 0.2s var(--ease);
  }
  .cap-tag:hover {
    border-color: var(--accent-line);
    color: var(--accent-deep);
    background: var(--accent-tint);
  }

  @media (max-width: 860px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 460px) {
    .about-stats {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }
</style>

<script>
  // Count the stat numbers up when they scroll into view.
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const statsEl = document.querySelector<HTMLElement>('.about-stats');

  if (statsEl && !reduced && 'IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          observer.disconnect();

          statsEl.querySelectorAll<HTMLElement>('.stat-value').forEach((el) => {
            const raw = (el.textContent ?? '').trim();
            const target = parseInt(raw, 10) || 0;
            const suffix = raw.replace(/[0-9]/g, '');
            const duration = 1400;
            const start = performance.now();

            const tick = (now: number) => {
              const t = Math.min(1, (now - start) / duration);
              const eased = 1 - Math.pow(1 - t, 3);
              el.textContent = Math.round(target * eased) + suffix;
              if (t < 1) requestAnimationFrame(tick);
            };

            el.textContent = '0' + suffix;
            requestAnimationFrame(tick);
          });
        });
      },
      { threshold: 0.4 }
    );
    observer.observe(statsEl);
  }
</script>
