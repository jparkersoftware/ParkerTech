---
import { site } from '../data/site';

const { about } = site;
---

<section class="section about" id="about">
  <div class="container">
    <div class="section-head" data-reveal>
      <span class="eyebrow">01 — About</span>
      <h2 class="section-title">From the classroom to the codebase.</h2>
    </div>

    <div class="about-grid">
      <div class="about-bio" data-reveal>
        {about.paragraphs.map((para) => <p>{para}</p>)}
      </div>

      <aside class="about-card" data-reveal style="--reveal-delay: 120ms">
        <p class="about-card-title">
          <span class="about-card-dot" aria-hidden="true"></span>
          What I can help with
        </p>
        <div class="cap-groups">
          {
            about.capabilities.map((group) => (
              <div class="cap-group">
                <h3 class="cap-group-name">{group.group}</h3>
                <ul class="cap-tags">
                  {group.items.map((item) => (
                    <li class="cap-tag">{item}</li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1.618fr 1fr;
    gap: clamp(1.5rem, 4vw, 3.25rem);
    align-items: start;
  }

  /* bio */
  .about-bio p {
    color: var(--text-muted);
    font-size: 1.06rem;
  }
  .about-bio p + p {
    margin-top: 1.1rem;
  }
  .about-bio p:first-child {
    color: var(--text);
    font-size: 1.2rem;
    line-height: 1.55;
  }

  /* "what I can help with" card */
  .about-card {
    position: relative;
    padding: 1.75rem;
    border-radius: var(--radius);
    background: var(--surface);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    overflow: hidden;
  }
  .about-card::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: var(--grad);
  }
  .about-card-title {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }
  .about-card-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-tint);
  }

  .cap-groups {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }
  .cap-group-name {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 0.7rem;
  }
  .cap-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .cap-tag {
    padding: 0.4rem 0.8rem;
    border-radius: var(--radius-pill);
    background: var(--fill);
    border: 1px solid var(--border);
    font-size: 0.86rem;
    color: var(--text);
    transition: border-color 0.2s var(--ease), color 0.2s var(--ease),
      background-color 0.2s var(--ease);
  }
  .cap-tag:hover {
    border-color: var(--accent-line);
    color: var(--accent-bright);
    background: var(--accent-tint);
  }

  @media (max-width: 860px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
