---
import { site } from '../data/site';
import Icon from './Icon.astro';
---

<section class="section contact" id="contact">
  <div class="container">
    <div class="section-head" data-reveal>
      <span class="eyebrow">04 — Get in touch</span>
      <h2 class="section-title">Have an idea, or a problem to solve?</h2>
      <p class="section-intro">
        Whether you'd like to use one of my tools, or there's a challenge in your
        school that needs a tool of its own — I'd genuinely like to hear about it.
      </p>
    </div>

    <div class="contact-grid">
      <!-- ── form ── -->
      <div class="contact-form-wrap" data-reveal>
        <form
          class="contact-form"
          id="contact-form"
          data-formspree-id={site.formspreeId}
          data-email={site.email}
        >
          <!-- honeypot: hidden from people, catches bots -->
          <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" aria-hidden="true" />

          <div class="field">
            <label for="cf-name">Name</label>
            <input
              id="cf-name"
              name="name"
              type="text"
              required
              autocomplete="name"
              placeholder="Your name"
            />
          </div>

          <div class="field">
            <label for="cf-email">Email</label>
            <input
              id="cf-email"
              name="email"
              type="email"
              required
              autocomplete="email"
              placeholder="you@yourschool.sch.uk"
            />
          </div>

          <div class="field">
            <label for="cf-message">Message</label>
            <textarea
              id="cf-message"
              name="message"
              rows="5"
              required
              placeholder="Tell me about your school and what you're trying to solve…"></textarea>
          </div>

          <button type="submit" class="btn btn-primary contact-submit">
            <span class="submit-label">Send message</span>
            <Icon name="arrow-right" size={18} class="arrow" />
          </button>

          <p class="form-status" id="form-status" role="status" aria-live="polite"></p>
        </form>

        <div class="form-success" id="form-success" hidden>
          <span class="form-success-icon"><Icon name="check" size={26} /></span>
          <h3>Message sent</h3>
          <p>Thanks for reaching out — I'll get back to you within a couple of days.</p>
        </div>
      </div>

      <!-- ── direct contact card ── -->
      <aside class="contact-card" data-reveal style="--reveal-delay: 120ms">
        <p class="contact-card-label">Prefer to email directly?</p>

        <a class="contact-email" href={`mailto:${site.email}`}>
          <span class="contact-email-icon"><Icon name="email" size={18} /></span>
          {site.email}
        </a>

        <dl class="contact-facts">
          <div>
            <dt>Location</dt>
            <dd>{site.location}</dd>
          </div>
          <div>
            <dt>Response time</dt>
            <dd>Within 1–2 days</dd>
          </div>
          {
            site.available && (
              <div>
                <dt>Availability</dt>
                <dd class="contact-available">
                  <span class="contact-available-dot" aria-hidden="true" />
                  Open to new projects
                </dd>
              </div>
            )
          }
        </dl>

        <p class="contact-card-note">
          No idea is too small — if it would make school life easier, it's worth
          a conversation.
        </p>
      </aside>
    </div>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(1.25rem, 3vw, 2.25rem);
    align-items: start;
  }

  /* ── form ── */
  .contact-form-wrap {
    position: relative;
    padding: clamp(1.5rem, 3.5vw, 2.4rem);
    border-radius: var(--radius);
    background: var(--surface);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
  }

  .field {
    margin-bottom: 1.15rem;
  }
  .field label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-muted);
  }
  .field input,
  .field textarea {
    width: 100%;
    padding: 0.8rem 0.95rem;
    border-radius: var(--radius-sm);
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text);
    font-size: 0.95rem;
    transition: border-color 0.2s var(--ease), box-shadow 0.2s var(--ease),
      background-color 0.2s var(--ease);
  }
  .field textarea {
    resize: vertical;
    min-height: 120px;
  }
  .field input::placeholder,
  .field textarea::placeholder {
    color: var(--text-dim);
  }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--accent);
    background: var(--surface);
    box-shadow: 0 0 0 4px rgba(13, 148, 136, 0.14);
  }

  /* honeypot — visually removed, still in the DOM for bots */
  input[name='_gotcha'] {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  .contact-submit {
    width: 100%;
    margin-top: 0.4rem;
  }
  .contact-submit:disabled {
    opacity: 0.65;
    cursor: progress;
  }

  .form-status {
    margin-top: 0.9rem;
    font-size: 0.88rem;
    min-height: 1.2em;
    color: var(--text-muted);
  }
  .form-status[data-kind='error'] {
    color: #b91c1c;
  }

  /* success state */
  .form-success {
    text-align: center;
    padding: 1.5rem 1rem;
  }
  .form-success[hidden] {
    display: none;
  }
  .form-success-icon {
    display: grid;
    place-items: center;
    width: 56px;
    height: 56px;
    margin: 0 auto 1.1rem;
    border-radius: 50%;
    background: rgba(22, 163, 74, 0.12);
    border: 1px solid rgba(22, 163, 74, 0.4);
    color: #16a34a;
  }
  .form-success h3 {
    font-size: 1.4rem;
  }
  .form-success p {
    margin-top: 0.5rem;
    color: var(--text-muted);
  }

  /* ── contact card ── */
  .contact-card {
    padding: clamp(1.5rem, 3.5vw, 2.2rem);
    border-radius: var(--radius);
    background: radial-gradient(
        circle at 100% 0%,
        rgba(13, 148, 136, 0.1),
        transparent 55%
      ),
      var(--surface);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
  }
  .contact-card-label {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .contact-email {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.85rem 1rem;
    border-radius: var(--radius-sm);
    background: var(--bg);
    border: 1px solid var(--border);
    font-weight: 600;
    font-size: 0.96rem;
    word-break: break-all;
    transition: border-color 0.2s var(--ease), background-color 0.2s var(--ease);
  }
  .contact-email-icon {
    display: grid;
    place-items: center;
    flex-shrink: 0;
    color: var(--accent-deep);
  }
  .contact-email:hover {
    border-color: var(--accent);
    background: var(--accent-tint);
  }

  .contact-facts {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .contact-facts div {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }
  .contact-facts dt {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .contact-facts dd {
    font-size: 0.92rem;
    font-weight: 500;
    text-align: right;
  }
  .contact-available {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: #15803d;
  }
  .contact-available-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #16a34a;
    box-shadow: 0 0 0 3px rgba(22, 163, 74, 0.18);
  }

  .contact-card-note {
    margin-top: 1.5rem;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  @media (max-width: 820px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const statusEl = document.getElementById('form-status') as HTMLElement;
  const successEl = document.getElementById('form-success') as HTMLElement;
  const submitBtn = form.querySelector('.contact-submit') as HTMLButtonElement;
  const labelEl = submitBtn.querySelector('.submit-label') as HTMLElement;

  const formId = form.dataset.formspreeId ?? '';
  const email = form.dataset.email ?? '';
  const configured = formId !== '' && formId !== 'YOUR_FORM_ID';

  const setStatus = (message: string, kind: 'error' | 'info' | '') => {
    statusEl.textContent = message;
    statusEl.dataset.kind = kind;
  };

  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const data = new FormData(form);

    // No Formspree set up yet — fall back to the visitor's email client.
    if (!configured) {
      const name = String(data.get('name') ?? '');
      const subject = encodeURIComponent(`Enquiry for ParkerTech from ${name}`);
      const body = encodeURIComponent(
        `${data.get('message') ?? ''}\n\n— ${name} (${data.get('email') ?? ''})`
      );
      window.location.href = `mailto:${email}?subject=${subject}&body=${body}`;
      setStatus('Opening your email app so you can send the message…', 'info');
      return;
    }

    submitBtn.disabled = true;
    labelEl.textContent = 'Sending…';
    setStatus('', '');

    try {
      const response = await fetch(`https://formspree.io/f/${formId}`, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });

      if (response.ok) {
        form.hidden = true;
        successEl.hidden = false;
        form.reset();
      } else {
        const json = await response.json().catch(() => null);
        const message = json?.errors?.[0]?.message ?? 'Something went wrong sending your message.';
        setStatus(`${message} You can also email me directly at ${email}.`, 'error');
      }
    } catch {
      setStatus(`Network error — please email me directly at ${email}.`, 'error');
    } finally {
      submitBtn.disabled = false;
      labelEl.textContent = 'Send message';
    }
  });
</script>
