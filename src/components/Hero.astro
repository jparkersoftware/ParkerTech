---
import { site } from '../data/site';
import Icon from './Icon.astro';

const { hero } = site;
---

<section class="hero" id="top">
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-grid"></div>
    <div class="hero-glow hero-glow-1"></div>
    <div class="hero-glow hero-glow-2"></div>
  </div>

  <div class="container hero-inner">
    {
      site.available && (
        <p class="hero-pill" data-reveal>
          <span class="hero-dot" aria-hidden="true" />
          {hero.eyebrow}
        </p>
      )
    }

    <h1 class="hero-title" data-reveal style="--reveal-delay: 80ms">
      {hero.titleLead}{' '}
      <span class="grad-text">{hero.titleAccent}</span>{' '}
      {hero.titleTail}
    </h1>

    <p class="hero-subtext" data-reveal style="--reveal-delay: 160ms">
      {hero.subtext}
    </p>

    <div class="hero-actions" data-reveal style="--reveal-delay: 240ms">
      <a class="btn btn-primary" href="#projects">
        Explore my projects
        <Icon name="arrow-right" size={18} class="arrow" />
      </a>
      <a class="btn btn-ghost" href="#contact">Get in touch</a>
    </div>

    <p class="hero-meta" data-reveal style="--reveal-delay: 320ms">
      <span>A decade in the classroom</span>
      <span class="hero-meta-sep" aria-hidden="true">/</span>
      <span>Now building for schools</span>
    </p>
  </div>

  <a class="hero-scroll" href="#projects" aria-label="Scroll to projects">
    <span>Scroll</span>
    <span class="hero-scroll-line" aria-hidden="true"></span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(100svh - var(--nav-h));
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-block: clamp(3rem, 9vw, 6rem);
  }

  /* ── background ── */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(36, 31, 24, 0.055) 1px, transparent 1px);
    background-size: 34px 34px;
    -webkit-mask-image: radial-gradient(ellipse 75% 65% at 50% 38%, #000 5%, transparent 75%);
    mask-image: radial-gradient(ellipse 75% 65% at 50% 38%, #000 5%, transparent 75%);
  }
  .hero-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(110px);
    opacity: 0.7;
  }
  .hero-glow-1 {
    width: 520px;
    height: 520px;
    top: -200px;
    left: -130px;
    background: radial-gradient(circle, rgba(13, 148, 136, 0.4), transparent 68%);
  }
  .hero-glow-2 {
    width: 480px;
    height: 480px;
    bottom: -220px;
    right: -120px;
    background: radial-gradient(circle, rgba(234, 138, 60, 0.3), transparent 68%);
  }

  /* ── content ── */
  .hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.45rem 0.95rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--border-strong);
    background: var(--surface);
    box-shadow: var(--shadow);
    font-size: 0.84rem;
    font-weight: 500;
    color: var(--text-muted);
  }
  .hero-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #16a34a;
    box-shadow: 0 0 0 0 rgba(22, 163, 74, 0.5);
    animation: pulse 2.4s infinite;
  }
  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(22, 163, 74, 0.5);
    }
    70% {
      box-shadow: 0 0 0 9px rgba(22, 163, 74, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(22, 163, 74, 0);
    }
  }

  .hero-title {
    margin-top: 1.6rem;
    max-width: 18ch;
    font-size: clamp(2.6rem, 7.2vw, 5rem);
    line-height: 1.06;
  }

  .hero-subtext {
    margin-top: 1.5rem;
    max-width: 62ch;
    color: var(--text-muted);
    font-size: clamp(1rem, 1.4vw, 1.18rem);
  }

  .hero-actions {
    margin-top: 2.25rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.85rem;
  }

  .hero-meta {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
    color: var(--text-dim);
  }
  .hero-meta-sep {
    color: var(--accent);
  }

  /* ── scroll cue ── */
  .hero-scroll {
    position: absolute;
    bottom: 1.6rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .hero-scroll-line {
    width: 1px;
    height: 38px;
    background: linear-gradient(180deg, var(--accent), transparent);
    overflow: hidden;
  }
  .hero-scroll-line::after {
    content: '';
    display: block;
    width: 100%;
    height: 12px;
    background: var(--accent-bright);
    animation: scroll-cue 2s var(--ease) infinite;
  }
  @keyframes scroll-cue {
    0% {
      transform: translateY(-12px);
    }
    100% {
      transform: translateY(38px);
    }
  }
  .hero-scroll:hover {
    color: var(--text-muted);
  }

  @media (max-width: 720px) {
    .hero-scroll {
      display: none;
    }
  }
</style>
