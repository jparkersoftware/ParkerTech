---
import { site } from '../data/site';
import Icon from './Icon.astro';

const { hero } = site;

// Split the headline into words so each can animate in on its own.
const headlineWords = [
  ...hero.titleLead.split(' ').map((w) => ({ w, accent: false })),
  ...hero.titleAccent.split(' ').map((w) => ({ w, accent: true })),
  ...hero.titleTail.split(' ').filter(Boolean).map((w) => ({ w, accent: false })),
];
---

<section class="hero" id="top">
  <div class="hero-bg" aria-hidden="true">
    <div class="aurora aurora-1"></div>
    <div class="aurora aurora-2"></div>
    <div class="aurora aurora-3"></div>
    <div class="hero-grid"></div>
  </div>

  <div class="container hero-inner">
    <h1 class="hero-title">
      {
        headlineWords.map((item, i) => (
          <span class="hero-word" style={`--i:${i}`}>
            <span class={item.accent ? 'grad-text' : ''}>{item.w}</span>
          </span>
        ))
      }
    </h1>

    <p class="hero-subtext">{hero.subtext}</p>

    <div class="hero-actions">
      <a class="btn btn-primary" href="#projects">
        Explore my projects
        <Icon name="arrow-right" size={18} class="arrow" />
      </a>
      <a class="btn btn-ghost" href="#contact">Get in touch</a>
    </div>

    <p class="hero-meta">
      <span>A decade in the classroom</span>
      <span class="hero-meta-sep" aria-hidden="true"></span>
      <span>Now building for schools</span>
    </p>
  </div>

  <a class="hero-scroll" href="#projects" aria-label="Scroll to projects">
    <span>Scroll</span>
    <span class="hero-scroll-line" aria-hidden="true"></span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(100svh - var(--nav-h));
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-block: clamp(3rem, 9vw, 6rem);
  }

  /* ── animated aurora background ── */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .aurora {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.6;
    will-change: transform;
  }
  .aurora-1 {
    width: 48vw;
    height: 48vw;
    max-width: 640px;
    max-height: 640px;
    top: -14vw;
    left: -10vw;
    background: radial-gradient(circle, rgba(125, 104, 255, 0.62), transparent 70%);
    animation: drift-1 24s var(--ease) infinite alternate;
  }
  .aurora-2 {
    width: 44vw;
    height: 44vw;
    max-width: 560px;
    max-height: 560px;
    bottom: -16vw;
    right: -8vw;
    background: radial-gradient(circle, rgba(93, 139, 255, 0.5), transparent 70%);
    animation: drift-2 30s var(--ease) infinite alternate;
  }
  .aurora-3 {
    width: 34vw;
    height: 34vw;
    max-width: 460px;
    max-height: 460px;
    top: 26%;
    right: 24%;
    background: radial-gradient(circle, rgba(168, 150, 255, 0.42), transparent 70%);
    animation: drift-3 20s var(--ease) infinite alternate;
  }
  @keyframes drift-1 {
    to {
      transform: translate(18%, 22%) scale(1.18);
    }
  }
  @keyframes drift-2 {
    to {
      transform: translate(-16%, -20%) scale(1.22);
    }
  }
  @keyframes drift-3 {
    to {
      transform: translate(-22%, 14%) scale(0.82);
    }
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.045) 1px, transparent 1px);
    background-size: 38px 38px;
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, #000 10%, transparent 78%);
    mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, #000 10%, transparent 78%);
  }

  /* ── content ── */
  .hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero-title {
    max-width: 16ch;
    font-size: clamp(2.9rem, 8.3vw, 6rem);
    line-height: 1.02;
    letter-spacing: -0.035em;
  }
  .hero-word {
    display: inline-block;
    margin-inline-end: 0.3em;
    opacity: 0;
    transform: translateY(0.55em);
    animation: word-in 0.72s var(--ease) forwards;
    animation-delay: calc(var(--i) * 55ms + 0.1s);
  }
  .hero-word .grad-text {
    display: inline-block;
  }
  @keyframes word-in {
    to {
      opacity: 1;
      transform: none;
    }
  }

  .hero-subtext {
    margin-top: 1.6rem;
    max-width: 60ch;
    color: var(--text-muted);
    font-size: clamp(1.02rem, 1.4vw, 1.2rem);
    opacity: 0;
    animation: rise 0.7s var(--ease) 0.7s forwards;
  }

  .hero-actions {
    margin-top: 2.3rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.85rem;
    opacity: 0;
    animation: rise 0.7s var(--ease) 0.85s forwards;
  }

  .hero-meta {
    margin-top: 2.1rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
    color: var(--text-dim);
    opacity: 0;
    animation: rise 0.7s var(--ease) 0.97s forwards;
  }
  .hero-meta-sep {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  /* ── scroll cue ── */
  .hero-scroll {
    position: absolute;
    bottom: 1.6rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-dim);
    opacity: 0;
    animation: rise 0.7s var(--ease) 1.15s forwards;
  }
  .hero-scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(180deg, var(--accent), transparent);
    overflow: hidden;
  }
  .hero-scroll-line::after {
    content: '';
    display: block;
    width: 100%;
    height: 13px;
    background: var(--accent-bright);
    animation: scroll-cue 2s var(--ease) infinite;
  }
  @keyframes scroll-cue {
    0% {
      transform: translateY(-13px);
    }
    100% {
      transform: translateY(40px);
    }
  }
  .hero-scroll:hover {
    color: var(--text-muted);
  }

  @media (max-width: 720px) {
    .hero-scroll {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-word,
    .hero-subtext,
    .hero-actions,
    .hero-meta,
    .hero-scroll {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .aurora {
      animation: none;
    }
  }
</style>
