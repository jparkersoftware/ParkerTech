---
import type { Project } from '../data/projects';
import Icon from './Icon.astro';

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;
const num = String(index + 1).padStart(2, '0');
const fit = project.coverFit ?? 'cover';
---

<article class="pcard" data-index={index} aria-roledescription="project">
  <div class="pcard-cover" data-fit={fit}>
    {
      project.cover ? (
        <img src={project.cover} alt={`${project.title} preview`} loading="lazy" />
      ) : (
        <div class="pcard-cover-fallback">
          <span class="grad-text">{num}</span>
        </div>
      )
    }
  </div>

  <div class="pcard-body">
    <div class="pcard-meta">
      <span class="pcard-kind" data-kind={project.kind}>{project.kind}</span>
      <span class="pcard-year">{project.year}</span>
    </div>

    <div class="pcard-head">
      {
        project.logo && (
          <img class="pcard-logo" src={project.logo} alt="" loading="lazy" />
        )
      }
      <h3 class="pcard-title">{project.title}</h3>
    </div>

    <p class="pcard-blurb">{project.blurb}</p>
    <p class="pcard-desc">{project.description}</p>

    <ul class="pcard-tags">
      {project.tags.map((tag) => <li>{tag}</li>)}
    </ul>

    <div class="pcard-foot">
      {
        project.liveUrl ? (
          <a
            class="pcard-link"
            href={project.liveUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            Visit {project.title}
            <Icon name="arrow-up-right" size={15} />
          </a>
        ) : (
          <p class="pcard-note">{project.note ?? 'Case study'}</p>
        )
      }
    </div>
  </div>
</article>

<style>
  .pcard {
    position: absolute;
    left: 50%;
    top: 50%;
    width: clamp(264px, 78vw, 384px);
    height: clamp(430px, 112vw, 540px);
    display: flex;
    flex-direction: column;
    border-radius: var(--radius);
    background: var(--surface);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    overflow: hidden;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transform: translate(-50%, -50%);
    transition: transform 0.6s var(--ease), opacity 0.5s var(--ease),
      border-color 0.4s var(--ease), box-shadow 0.4s var(--ease);
    cursor: pointer;
    will-change: transform, opacity;
  }
  .pcard.is-active {
    border-color: var(--accent-line);
    box-shadow: var(--shadow-lg), 0 0 70px -14px rgba(125, 104, 255, 0.55);
    cursor: default;
  }

  /* cover */
  .pcard-cover {
    position: relative;
    aspect-ratio: 1.618 / 1;
    flex-shrink: 0;
    overflow: hidden;
    background: var(--bg-soft);
    border-bottom: 1px solid var(--border);
  }
  .pcard-cover img {
    width: 100%;
    height: 100%;
    display: block;
  }
  .pcard-cover[data-fit='cover'] img {
    object-fit: cover;
    object-position: top center;
  }
  .pcard-cover[data-fit='contain'] img {
    object-fit: contain;
    padding: 1.5rem;
  }
  .pcard-cover-fallback {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    background: radial-gradient(
      circle at 70% 30%,
      rgba(125, 104, 255, 0.3),
      rgba(93, 139, 255, 0.1) 55%,
      transparent 80%
    );
  }
  .pcard-cover-fallback span {
    font-family: var(--font-display);
    font-size: 4.5rem;
    font-weight: 800;
    line-height: 1;
  }

  /* body */
  .pcard-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: clamp(1.15rem, 3.4vw, 1.6rem);
  }
  .pcard-meta {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
  }
  .pcard-kind {
    padding: 0.22rem 0.6rem;
    border-radius: var(--radius-pill);
    font-size: 0.66rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .pcard-kind[data-kind='Product'] {
    background: var(--accent-tint);
    border: 1px solid var(--accent-line);
    color: var(--accent-bright);
  }
  .pcard-kind[data-kind='Bespoke build'] {
    background: rgba(245, 184, 100, 0.13);
    border: 1px solid rgba(245, 184, 100, 0.4);
    color: #f4c88c;
  }
  .pcard-year {
    margin-inline-start: auto;
    color: var(--text-dim);
  }

  .pcard-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 0.85rem;
  }
  .pcard-logo {
    height: 30px;
    width: auto;
    flex-shrink: 0;
  }
  .pcard-title {
    font-size: clamp(1.25rem, 3.4vw, 1.5rem);
  }
  .pcard-blurb {
    margin-top: 0.5rem;
    color: var(--accent-bright);
    font-weight: 600;
    font-size: 0.95rem;
  }
  .pcard-desc {
    margin-top: 0.5rem;
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .pcard-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.9rem;
  }
  .pcard-tags li {
    padding: 0.26rem 0.58rem;
    border-radius: 7px;
    background: var(--fill);
    border: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-muted);
  }
  .pcard-foot {
    margin-top: auto;
    padding-top: 1.1rem;
  }
  .pcard-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--accent-bright);
    transition: gap 0.2s var(--ease);
  }
  .pcard-link:hover {
    gap: 0.6rem;
  }
  .pcard-note {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.84rem;
    color: var(--text-dim);
  }
  .pcard-note::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--text-dim);
    flex-shrink: 0;
  }

  /* ── mobile: cards sit in a native scroll-snap row ── */
  @media (max-width: 760px) {
    .pcard {
      position: relative;
      left: auto;
      top: auto;
      transform: none;
      opacity: 1;
      flex: 0 0 auto;
      height: clamp(454px, 122vw, 540px);
      scroll-snap-align: center;
      will-change: auto;
      /* the frosted blur is imperceptible over the flat dark
         background here — drop it to keep scrolling smooth */
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }
  }
</style>
