---
import { site } from '../data/site';
import { projects } from '../data/projects';

const year = new Date().getFullYear();
const sections = [
  { href: '/#projects', label: 'Projects' },
  { href: '/#about', label: 'About' },
  { href: '/#it-support', label: 'IT support' },
  { href: '/#contact', label: 'Contact' },
];
const tools = projects.filter((p) => p.liveUrl);
---

<footer class="footer">
  <div class="footer-glow" aria-hidden="true"></div>
  <div class="container footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <a class="brand" href="/#top" aria-label={`${site.brand} — home`}>
          <span class="brand-word">Parker<span class="brand-accent">Tech</span></span>
        </a>
        <p class="footer-tagline">
          Educational technology for schools — built by a developer who spent a
          decade teaching in them.
        </p>
        <a class="footer-cta" href={`mailto:${site.email}`}>{site.email}</a>
      </div>

      <div class="footer-cols">
        <nav class="footer-nav" aria-label="Footer">
          <span class="footer-col-title">Site</span>
          {sections.map((s) => <a href={s.href}>{s.label}</a>)}
        </nav>
        {
          tools.length > 0 && (
            <div class="footer-nav">
              <span class="footer-col-title">Tools</span>
              {tools.map((tool) => (
                <a href={tool.liveUrl} target="_blank" rel="noopener noreferrer">
                  {tool.title}
                </a>
              ))}
            </div>
          )
        }
      </div>
    </div>

    <div class="footer-bottom">
      <p>© {year} {site.brand}. All rights reserved.</p>
      <div class="footer-bottom-links">
        <a href="/privacy">Privacy &amp; cookies</a>
        <a class="footer-top-link" href="#main">
          Back to top
          <span class="footer-arrow" aria-hidden="true">↑</span>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    background: var(--bg-soft);
    border-top: 1px solid var(--border);
    padding-block: clamp(3.25rem, 6vw, 5rem) 2rem;
    overflow: hidden;
  }
  .footer-glow {
    position: absolute;
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 380px;
    background: radial-gradient(circle, rgba(125, 104, 255, 0.28), transparent 70%);
    filter: blur(90px);
    pointer-events: none;
  }
  .footer-inner {
    position: relative;
  }

  .footer-top {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 2.5rem;
  }

  .footer-brand {
    max-width: 360px;
  }
  .brand {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.4rem;
    letter-spacing: -0.035em;
  }
  .brand-accent {
    background: linear-gradient(120deg, #a294ff, #7d68ff);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .footer-tagline {
    margin-top: 1rem;
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }
  .footer-cta {
    display: inline-block;
    margin-top: 1.1rem;
    font-weight: 600;
    color: var(--accent-bright);
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s var(--ease);
  }
  .footer-cta:hover {
    border-bottom-color: var(--accent-bright);
  }

  .footer-cols {
    display: flex;
    gap: clamp(2.5rem, 8vw, 5rem);
  }
  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .footer-col-title {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 0.3rem;
  }
  .footer-nav a {
    color: var(--text-muted);
    font-size: 0.95rem;
    width: fit-content;
    transition: color 0.2s var(--ease);
  }
  .footer-nav a:hover {
    color: var(--text);
  }

  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    margin-top: clamp(2.75rem, 5vw, 4rem);
    padding-top: 1.75rem;
    border-top: 1px solid var(--border);
    color: var(--text-dim);
    font-size: 0.86rem;
  }
  .footer-bottom-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .footer-bottom-links a {
    color: var(--text-muted);
    font-weight: 500;
    transition: color 0.2s var(--ease);
  }
  .footer-bottom-links a:hover {
    color: var(--text);
  }
  .footer-top-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-muted);
    font-weight: 500;
    transition: color 0.2s var(--ease);
  }
  .footer-top-link:hover {
    color: var(--text);
  }
  .footer-arrow {
    transition: transform 0.2s var(--ease);
  }
  .footer-top-link:hover .footer-arrow {
    transform: translateY(-3px);
  }

  @media (max-width: 540px) {
    .footer-cols {
      width: 100%;
      justify-content: space-between;
    }
  }
</style>
