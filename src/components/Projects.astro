---
import { projects } from '../data/projects';
import ProjectCard from './ProjectCard.astro';
import Icon from './Icon.astro';
---

<section class="section section-soft projects" id="projects">
  <div class="container">
    <div class="section-head" data-reveal>
      <span class="eyebrow">02 — Projects</span>
      <h2 class="section-title">Tools I've built for schools.</h2>
      <p class="section-intro">
        From products any school can pick up and use, to bespoke tools made for a
        single school. Drag the deck, or use the controls below.
      </p>
    </div>
  </div>

  <div class="coverflow" id="coverflow-region" data-reveal>
    <div class="cf-stage" id="cf-stage">
      {projects.map((project, i) => <ProjectCard project={project} index={i} />)}
    </div>
  </div>

  <div class="container">
    <div class="cf-controls">
      <button class="cf-arrow is-prev" id="cf-prev" type="button" aria-label="Previous project">
        <Icon name="arrow-right" size={20} />
      </button>
      <div class="cf-dots" id="cf-dots" role="tablist" aria-label="Choose a project">
        {
          projects.map((project, i) => (
            <button class="cf-dot" type="button" data-i={i} aria-label={project.title} />
          ))
        }
      </div>
      <button class="cf-arrow" id="cf-next" type="button" aria-label="Next project">
        <Icon name="arrow-right" size={20} />
      </button>
    </div>
  </div>
</section>

<style>
  .coverflow {
    position: relative;
    margin-top: clamp(1rem, 3vw, 2rem);
    padding-block: clamp(1.75rem, 4vw, 3.25rem);
    perspective: 1700px;
    perspective-origin: 50% 44%;
    overflow: hidden;
  }
  .cf-stage {
    position: relative;
    height: clamp(430px, 112vw, 540px);
    transform-style: preserve-3d;
    touch-action: pan-y;
    cursor: grab;
  }
  .cf-stage:active {
    cursor: grabbing;
  }

  .cf-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.4rem;
    margin-top: clamp(1.25rem, 3vw, 2.25rem);
  }
  .cf-arrow {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--surface);
    border: 1px solid var(--border-strong);
    color: var(--text);
    cursor: pointer;
    transition: transform 0.2s var(--ease), background-color 0.2s var(--ease),
      border-color 0.2s var(--ease), color 0.2s var(--ease), opacity 0.2s var(--ease);
  }
  .cf-arrow:hover:not(:disabled) {
    background: var(--surface-hover);
    border-color: var(--accent);
    color: var(--accent-bright);
    transform: translateY(-2px);
  }
  .cf-arrow:disabled {
    opacity: 0.32;
    cursor: not-allowed;
  }
  .cf-arrow.is-prev :global(svg) {
    transform: scaleX(-1);
  }

  .cf-dots {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .cf-dot {
    width: 8px;
    height: 8px;
    padding: 0;
    border: none;
    border-radius: var(--radius-pill);
    background: var(--border-strong);
    cursor: pointer;
    transition: width 0.3s var(--ease), background-color 0.3s var(--ease);
  }
  .cf-dot:hover {
    background: var(--text-dim);
  }
  .cf-dot[aria-current='true'] {
    width: 28px;
    background: var(--accent);
  }
</style>

<script>
  const stage = document.getElementById('cf-stage');

  if (stage) {
    const cards = Array.from(stage.querySelectorAll<HTMLElement>('.pcard'));
    const dots = Array.from(document.querySelectorAll<HTMLButtonElement>('.cf-dot'));
    const prevBtn = document.getElementById('cf-prev') as HTMLButtonElement;
    const nextBtn = document.getElementById('cf-next') as HTMLButtonElement;
    const region = document.getElementById('coverflow-region');
    const count = cards.length;

    let active = 0;
    let justDragged = false;

    const render = () => {
      const w = cards[0]?.offsetWidth || 340;
      const gap = w * 0.56;

      cards.forEach((card, i) => {
        const d = i - active;
        const ad = Math.abs(d);
        const dir = Math.sign(d);
        const x = d === 0 ? 0 : dir * (gap + (ad - 1) * gap * 0.62);
        const ry = d === 0 ? 0 : -dir * (ad === 1 ? 44 : 56);
        const tz = -Math.min(ad, 3) * 155;
        const scale = d === 0 ? 1 : Math.max(0.68, 0.84 - (ad - 1) * 0.1);

        card.style.transform =
          `translate(-50%, -50%) translateX(${x}px) translateZ(${tz}px) rotateY(${ry}deg) scale(${scale})`;
        card.style.opacity = ad === 0 ? '1' : ad === 1 ? '0.72' : ad === 2 ? '0.32' : '0';
        card.style.zIndex = String(30 - ad);
        card.style.pointerEvents = ad <= 2 ? 'auto' : 'none';
        card.classList.toggle('is-active', d === 0);
        card.setAttribute('aria-hidden', d === 0 ? 'false' : 'true');
      });

      dots.forEach((dot, i) =>
        dot.setAttribute('aria-current', i === active ? 'true' : 'false')
      );
      prevBtn.disabled = active === 0;
      nextBtn.disabled = active === count - 1;
    };

    const go = (to: number) => {
      active = Math.max(0, Math.min(count - 1, to));
      render();
    };

    prevBtn.addEventListener('click', () => go(active - 1));
    nextBtn.addEventListener('click', () => go(active + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => go(i)));

    cards.forEach((card, i) => {
      card.addEventListener('click', (event) => {
        if (justDragged) {
          event.preventDefault();
          return;
        }
        if (i !== active) {
          event.preventDefault();
          go(i);
        }
      });
    });

    // drag / swipe
    let startX = 0;
    let pointerDown = false;
    stage.addEventListener('pointerdown', (event) => {
      pointerDown = true;
      justDragged = false;
      startX = event.clientX;
    });
    window.addEventListener('pointerup', (event) => {
      if (!pointerDown) return;
      pointerDown = false;
      const dx = event.clientX - startX;
      if (Math.abs(dx) > 45) {
        justDragged = true;
        go(active + (dx < 0 ? 1 : -1));
        setTimeout(() => {
          justDragged = false;
        }, 0);
      }
    });

    // keyboard
    region?.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowLeft') {
        event.preventDefault();
        go(active - 1);
      } else if (event.key === 'ArrowRight') {
        event.preventDefault();
        go(active + 1);
      }
    });

    render();
    window.addEventListener('resize', render);
  }
</script>
