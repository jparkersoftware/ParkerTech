rules_version = '2';

// Single-tenant rules: only the owner UID can read or write anything.
// Mirrors the ALLOWED_UID constant in src/components/command-centre/lib/firebase.ts.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == 'vLqAisb7mAd93ZSF6Lq0IaS32hy2';
    }
  }
}
