rules_version = '2';

// Single-tenant rules: only the owner UID can read or write any file.
// Mirrors the firestore.rules ALLOWED_UID restriction. First needed when
// the Expenses feature shipped (receipts + supplier-invoice PDFs upload
// to expenses/{YYYY}/{MM}/{expenseId}/{uuid}.{ext}).
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == 'vLqAisb7mAd93ZSF6Lq0IaS32hy2';
    }
  }
}
