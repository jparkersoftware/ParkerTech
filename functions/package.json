{
  "name": "parkertech-functions",
  "private": true,
  "version": "0.1.0",
  "description": "Firebase Functions backend for the ParkerTech Command Centre (Gmail integration, etc.).",
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc -w",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.0.0",
    "googleapis": "^144.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
